# DAB AI gateway — environment contract.
#
# Copy to .env and fill in real values:  cp .env.example .env
# .env is git-ignored; never commit real secrets. Only this file is tracked.
# Every variable the backend reads (internal/config.Load) is listed here; a
# drift test fails the build if one is missing.

# ── Runtime (backend) ────────────────────────────────────────────────────────
# ENV: deployment label (development|staging|production). Consumed by: backend.
ENV=development
# LISTEN_ADDR: address the gateway binds to; overrides PORT when set. Consumed by: backend.
LISTEN_ADDR=:8080
# PORT: convenience alternative to LISTEN_ADDR (gateway listens on :PORT). Consumed by: backend.
PORT=8080
# LOG_LEVEL: structured log level (debug|info|warn|error). Consumed by: backend.
LOG_LEVEL=info
# SHUTDOWN_GRACE: max drain time for in-flight requests on shutdown (Go duration). Consumed by: backend.
SHUTDOWN_GRACE=10s

# ── Postgres ─────────────────────────────────────────────────────────────────
# POSTGRES_USER/PASSWORD/DB: credentials the postgres container is initialised with. Consumed by: postgres (compose).
POSTGRES_USER=dab
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=dab
# DATABASE_URL: Postgres DSN the gateway connects with; host is the compose service name `postgres`. Consumed by: backend.
DATABASE_URL=postgres://dab:change-me-postgres-password@postgres:5432/dab?sslmode=disable
# AUTO_MIGRATE: run pending DB migrations on startup (true|false). Consumed by: backend.
AUTO_MIGRATE=false

# ── vLLM upstream ────────────────────────────────────────────────────────────
# VLLM_URL: base URL of the self-hosted vLLM OpenAI-compatible server (compose service `qwen`). Consumed by: backend.
VLLM_URL=http://qwen:8000
# VLLM_API_KEY: shared secret the gateway sends to vLLM. Gateway->vLLM credential ONLY; never exposed to projects. Consumed by: backend.
VLLM_API_KEY=change-me-vllm-shared-key

# ── Auth / security (backend) ────────────────────────────────────────────────
# JWT_SECRET: signing secret for admin session JWTs. Required, non-empty. Consumed by: backend.
JWT_SECRET=change-me-jwt-signing-secret
# CORS_ALLOWED_ORIGINS: comma-separated origins allowed to call the gateway (e.g. the frontend). Consumed by: backend.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ── Rate limiting (backend) ──────────────────────────────────────────────────
# LOGIN_RATE_LIMIT_RPM / _BURST: per-IP limit on the admin login endpoint. Consumed by: backend.
LOGIN_RATE_LIMIT_RPM=10
LOGIN_RATE_LIMIT_BURST=5
# GATEWAY_RATE_LIMIT_RPM / _BURST: per-API-key limit on the LLM gateway endpoint. Consumed by: backend.
GATEWAY_RATE_LIMIT_RPM=120
GATEWAY_RATE_LIMIT_BURST=40

# ── Frontend (build-time, public) ────────────────────────────────────────────
# NEXT_PUBLIC_API_BASE_URL: gateway base URL baked into the frontend bundle. PUBLIC — not a secret. Consumed by: frontend (build).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
